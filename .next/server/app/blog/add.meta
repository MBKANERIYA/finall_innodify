{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/add/layout,_N_T_/blog/add/page,_N_T_/blog/add"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/blog/add/__PAGE__",
    "/blog/add",
    "/blog",
    "/_index",
    "/_head"
  ]
}